<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_onboarding"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="100dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jurnal Syukur"
            android:textColor="@color/white"
            android:textSize="38sp"
            android:fontFamily="@font/poppins_light"
            android:letterSpacing="-0.02" />

        <!-- Quote Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_glass_simple"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <TextView
                android:id="@+id/tv_quote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_light"
                android:background="@drawable/bg_card_glass_simple"
                android:padding="20dp"
                android:text="&quot;Gratitude turns what we have into enough.&quot; 💚"
                android:textAlignment="center"
                android:textColor="#B4D96C"
                android:textSize="16sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Apa yang kamu syukuri hari ini?"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_medium"
            android:textSize="20sp" />

        <!-- Item 1 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="1. Tulis sesuatu yang kamu syukuri..."
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:counterEnabled="true"
            app:counterMaxLength="100">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_item_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLength="100" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Item 2 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="2. Tulis sesuatu yang kamu syukuri... (opsional)"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:counterEnabled="true"
            app:counterMaxLength="100">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_item_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLength="100" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Item 3 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="3. Tulis sesuatu yang kamu syukuri... (opsional)"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:counterEnabled="true"
            app:counterMaxLength="100">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_item_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLength="100" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save Button - Premium Pill -->
        <Button
            android:id="@+id/btn_save_journal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_large"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_button_pill_primary"
            android:text="Simpan Jurnal"
            android:textColor="@color/darkBackground"
            android:fontFamily="@font/poppins_medium"
            android:textSize="16sp"
            android:elevation="0dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="32dp"
            android:background="#33FFFFFF" />

        <!-- Stats Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Statistik"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_medium"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/tv_monthly_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Kamu sudah menulis 23 hari bulan ini!"
            android:textColor="#B3FFFFFF"
            android:fontFamily="@font/poppins_regular"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_motivation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Pertahankan! 🔥"
            android:textColor="#B4D96C"
            android:fontFamily="@font/poppins_medium"
            android:textSize="16sp" />

        <!-- Streak Tracker Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_streak"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_glass_simple"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_glass_simple"
                android:padding="20dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥"
                    android:textSize="48sp"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_streak_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7 Hari Streak!"
                        android:textColor="@color/mintGreen"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Kamu konsisten menulis gratitude! ✨"
                        android:textColor="#B3FFFFFF"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Recent Entries -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Entri Terakhir"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_medium"
            android:textSize="24sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_recent_entries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_card_glass_simple"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_glass_simple"
                android:padding="20dp">

                <!-- Will be populated dynamically -->
                <TextView
                    android:id="@+id/tv_recent_entries"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Belum ada entri"
                    android:textColor="#B3FFFFFF"
                    android:fontFamily="@font/poppins_regular"
                    android:lineSpacingExtra="6dp"
                    android:textSize="15sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
