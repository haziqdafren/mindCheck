<?xml version="1.0" encoding="utf-8"?>
<!-- Premium Register Screen - Organic Design with Glassmorphism -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_onboarding"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_l">

        <!-- Logo -->
        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_lotus_minimal"
            android:contentDescription="MindCheck Logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/spacing_xl"
            android:alpha="0.95" />

        <!-- Welcome Text -->
        <TextView
            android:id="@+id/tv_welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mulai Perjalanan Anda"
            android:textSize="@dimen/text_headline"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="-0.02"
            app:layout_constraintTop_toBottomOf="@id/iv_logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/spacing_l" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buat akun untuk melanjutkan"
            android:textSize="@dimen/text_body_small"
            android:textColor="#B3FFFFFF"
            android:alpha="0.8"
            android:fontFamily="sans-serif"
            app:layout_constraintTop_toBottomOf="@id/tv_welcome"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/spacing_xs" />

        <!-- Name Input -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:background="@drawable/bg_card_glass_simple"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="@dimen/radius_l"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_glass_simple"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Lengkap"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="13sp"
                    android:alpha="0.9" />

                <EditText
                    android:id="@+id/et_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Masukkan nama lengkap"
                    android:inputType="textPersonName"
                    android:textColor="@color/white"
                    android:textColorHint="@color/seafoamGreen"
                    android:fontFamily="sans-serif"
                    android:textSize="@dimen/text_body"
                    android:background="@null"
                    android:paddingTop="@dimen/spacing_s" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Email Input -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_m"
            android:background="@drawable/bg_card_glass_simple"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="@dimen/radius_l"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/card_name">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_glass_simple"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#99FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="13sp"
                    android:alpha="0.9" />

                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="nama@email.com"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/white"
                    android:textColorHint="@color/seafoamGreen"
                    android:fontFamily="sans-serif"
                    android:textSize="@dimen/text_body"
                    android:background="@null"
                    android:paddingTop="@dimen/spacing_s" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Password Input -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_m"
            android:background="@drawable/bg_card_glass_simple"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="@dimen/radius_l"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/card_email">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_glass_simple"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textColor="#99FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="13sp"
                    android:alpha="0.9" />

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Minimal 6 karakter"
                    android:inputType="textPassword"
                    android:textColor="@color/white"
                    android:textColorHint="@color/seafoamGreen"
                    android:fontFamily="sans-serif"
                    android:textSize="@dimen/text_body"
                    android:background="@null"
                    android:paddingTop="@dimen/spacing_s" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Confirm Password Input -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_confirm_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_m"
            android:background="@drawable/bg_card_glass_simple"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="@dimen/radius_l"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/card_password">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_glass_simple"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Konfirmasi Password"
                    android:textColor="#99FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="13sp"
                    android:alpha="0.9" />

                <EditText
                    android:id="@+id/et_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ketik ulang password"
                    android:inputType="textPassword"
                    android:textColor="@color/white"
                    android:textColorHint="@color/seafoamGreen"
                    android:fontFamily="sans-serif"
                    android:textSize="@dimen/text_body"
                    android:background="@null"
                    android:paddingTop="@dimen/spacing_s" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Error Message -->
        <TextView
            android:id="@+id/tv_error"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/errorRed"
            android:fontFamily="sans-serif"
            android:textSize="@dimen/text_caption"
            android:visibility="gone"
            android:alpha="0.9"
            app:layout_constraintTop_toBottomOf="@id/card_confirm_password"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/spacing_s" />

        <!-- Register Button -->
        <Button
            android:id="@+id/btn_register"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:text="Daftar"
            android:textSize="@dimen/text_body"
            android:textColor="@color/darkBackground"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.02"
            android:background="@drawable/bg_button_pill_primary"
            android:elevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/tv_error"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/spacing_l" />

        <!-- Login Link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/btn_register"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/spacing_l"
            android:layout_marginBottom="@dimen/spacing_l">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sudah punya akun? "
                android:textColor="#B3FFFFFF"
                android:alpha="0.7"
                android:fontFamily="sans-serif"
                android:textSize="@dimen/text_body_small" />

            <TextView
                android:id="@+id/tv_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Masuk"
                android:textColor="#99FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:textSize="@dimen/text_body_small" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
