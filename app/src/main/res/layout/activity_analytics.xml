<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_onboarding"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analitik Kesehatan Mental"
            android:textColor="@color/white"
            android:textSize="38sp"
            android:fontFamily="@font/poppins_light"
            android:letterSpacing="-0.02" />

        <!-- Wellness Score Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/gradient_card_featured"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/gradient_card_featured"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skor Wellness"
                    android:textColor="#E0FFFFFF"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tv_wellness_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="78/100"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_light"
                    android:textSize="56sp" />

                <ProgressBar
                    android:id="@+id/progress_wellness"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="240dp"
                    android:layout_height="8dp"
                    android:layout_marginTop="20dp"
                    android:max="100"
                    android:progress="78"
                    android:progressTint="@color/white" />

                <TextView
                    android:id="@+id/tv_score_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Baik!"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_medium"
                    android:textSize="22sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Summary Stats -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Ringkasan Bulan Ini"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_medium"
            android:textSize="24sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <!-- Mood Days -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_glass_simple"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_glass_simple"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_mood_days"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="23 hari"
                        android:textColor="#B4D96C"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Mood"
                        android:textColor="#B3FFFFFF"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sleep -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_glass_simple"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_glass_simple"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_avg_sleep"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7.4 jam"
                        android:textColor="#B4D96C"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tidur"
                        android:textColor="#B3FFFFFF"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <!-- Gratitude -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_glass_simple"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_glass_simple"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_gratitude_days"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="23 hari"
                        android:textColor="#B4D96C"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Jurnal"
                        android:textColor="#B3FFFFFF"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Goals -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_glass_simple"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_glass_simple"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_active_goals"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3 target"
                        android:textColor="#B4D96C"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Goals"
                        android:textColor="#B3FFFFFF"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Screening History -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Riwayat Screening"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_medium"
            android:textSize="24sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_glass_simple"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_glass_simple"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_screening_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="6dp"
                    android:text="• 3 hari lalu - Risiko Rendah\n• 10 hari lalu - Risiko Rendah"
                    android:textColor="#B3FFFFFF"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="15sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Mood Trend Chart -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Mood Trend (7 Hari Terakhir)"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_medium"
            android:textSize="24sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_glass_simple"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_glass_simple"
                android:padding="20dp">

                <!-- Chart container -->
                <LinearLayout
                    android:id="@+id/mood_chart_container"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:baselineAligned="false" />

                <!-- Chart legend -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <View
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:background="@drawable/bg_mood_very_good" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="12dp"
                        android:text="Sangat Baik"
                        android:textColor="#B3FFFFFF"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="11sp" />

                    <View
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:background="@drawable/bg_mood_good" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="12dp"
                        android:text="Baik"
                        android:textColor="#B3FFFFFF"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="11sp" />

                    <View
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:background="@drawable/bg_mood_normal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="12dp"
                        android:text="Biasa"
                        android:textColor="#B3FFFFFF"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="11sp" />

                    <View
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:background="@drawable/bg_mood_low" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Rendah"
                        android:textColor="#B3FFFFFF"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Empty state message -->
                <TextView
                    android:id="@+id/tv_mood_chart_empty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="32dp"
                    android:text="Mulai catat mood kamu untuk melihat grafik"
                    android:textColor="#80FFFFFF"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
