<?xml version="1.0" encoding="utf-8"?>
<!-- Layout halaman Target Wellness dengan daftar target dan tugas -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_onboarding"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="100dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Judul halaman -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Target Wellness"
            android:textColor="@color/white"
            android:textSize="38sp"
            android:fontFamily="@font/poppins_light"
            android:letterSpacing="-0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Wujudkan target wellness kamu"
            android:textColor="#B3FFFFFF"
            android:alpha="0.8"
            android:fontFamily="@font/poppins_regular"
            android:textSize="15sp" />

        <!-- Bagian fokus tugas hari ini -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="📋 Fokus Hari Ini"
            android:textColor="#B4D96C"
            android:fontFamily="@font/poppins_medium"
            android:textSize="22sp" />

        <!-- Kartu daftar tugas hari ini -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_today_tasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_glass_simple"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_glass_simple"
                android:padding="20dp">

                <!-- Daftar tugas hari ini akan ditampilkan di sini -->
                <LinearLayout
                    android:id="@+id/container_today_tasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Tampilan kosong saat tidak ada tugas hari ini -->
                <TextView
                    android:id="@+id/tv_today_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎉 Tidak ada tugas hari ini!\nBuat target baru atau nikmati istirahat."
                    android:textColor="#B3FFFFFF"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="14sp"
                    android:textAlignment="center"
                    android:padding="24dp"
                    android:lineSpacingMultiplier="1.4"
                    android:visibility="gone" />

                <!-- Indikator konsistensi penyelesaian tugas -->
                <LinearLayout
                    android:id="@+id/container_streak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@drawable/bg_card_glass_simple"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥 Streak 5 hari!"
                        android:textColor="#B4D96C"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Baris statistik cepat -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Jumlah target yang aktif -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_card_glass_simple"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_glass_simple"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_active_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#B4D96C"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Target Aktif"
                        android:textColor="#B3FFFFFF"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Persentase penyelesaian tugas -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_card_glass_simple"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_glass_simple"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_completion_rate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="#B4D96C"
                        android:fontFamily="@font/poppins_medium"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Penyelesaian"
                        android:textColor="#B3FFFFFF"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Tombol untuk membuat target baru -->
        <Button
            android:id="@+id/btn_add_goal"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_pill_primary"
            android:text="+ Buat Target Baru"
            android:textColor="@color/darkBackground"
            android:fontFamily="@font/poppins_medium"
            android:textSize="16sp"
            android:elevation="0dp" />

        <!-- Bagian daftar target pengguna -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Target Saya"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_medium"
            android:textSize="22sp" />

        <!-- Container untuk kartu-kartu target -->
        <LinearLayout
            android:id="@+id/goal_progress_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical" />

        <!-- Tampilan kosong saat belum ada target -->
        <TextView
            android:id="@+id/tv_progress_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:text="Belum ada target\nMulai buat target pertama kamu!"
            android:textColor="#80FFFFFF"
            android:fontFamily="@font/poppins_regular"
            android:textAlignment="center"
            android:lineSpacingMultiplier="1.3"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Kartu tips untuk mencapai target -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_card_glass_simple"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_glass_simple"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 Tips Sukses"
                    android:textColor="#B4D96C"
                    android:fontFamily="@font/poppins_medium"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="• Mulai dengan 1-2 target yang realistis\n• Buat tugas kecil yang mudah diselesaikan\n• Konsisten lebih penting dari sempurna\n• Rayakan pencapaian kecil kamu!"
                    android:textColor="#B3FFFFFF"
                    android:fontFamily="@font/poppins_regular"
                    android:lineSpacingMultiplier="1.5"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
