<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_onboarding"
    android:padding="24dp">

    <!-- Progress Bar at Top -->
    <LinearLayout
        android:id="@+id/progressContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvProgressText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pertanyaan 1 dari 10"
                android:textSize="13sp"
                android:textColor="#99FFFFFF"
                android:fontFamily="@font/poppins_regular" />

            <TextView
                android:id="@+id/tvProgressPercentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10%"
                android:textSize="13sp"
                android:textColor="#B4D96C"
                android:fontFamily="@font/poppins_medium" />
        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:progress="10"
            android:progressTint="#B4D96C"
            android:progressBackgroundTint="#40FFFFFF"
            android:max="100" />
    </LinearLayout>

    <!-- Question Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/progressContainer"
        app:layout_constraintBottom_toTopOf="@id/buttonContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Question Icon -->
            <ImageView
                android:id="@+id/ivQuestionIcon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_gender"
                android:tint="@color/white"
                android:layout_marginBottom="16dp" />

            <!-- Question Title -->
            <TextView
                android:id="@+id/tvQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Jenis kelamin kamu?"
                android:textSize="32sp"
                android:textColor="@color/white"
                android:fontFamily="@font/poppins_light"
                android:letterSpacing="-0.01"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="12dp" />

            <!-- Question Description (optional) -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pilih yang sesuai"
                android:textSize="15sp"
                android:textColor="#B3FFFFFF"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="32dp"
                android:visibility="gone" />

            <!-- Answer Container - Will be populated dynamically based on question type -->
            <LinearLayout
                android:id="@+id/answerContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <!-- Dynamic content will be added here -->
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Buttons -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp">

        <!-- Back Button -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_weight="1"
            android:text="← Kembali"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_medium"
            android:gravity="center"
            android:background="@drawable/bg_glass_button_dark"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="12dp" />

        <!-- Next Button -->
        <TextView
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_weight="1"
            android:text="Lanjut →"
            android:textSize="16sp"
            android:textColor="#2B3A2B"
            android:fontFamily="@font/poppins_medium"
            android:gravity="center"
            android:background="@drawable/bg_glass_button_light"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="12dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
