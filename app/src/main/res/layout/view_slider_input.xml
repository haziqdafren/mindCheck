<?xml version="1.0" encoding="utf-8"?>
<!-- Slider input for scale-based questions (1-5) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_glass_simple"
    android:padding="24dp">

    <!-- Current Value Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/tvSliderValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:textSize="48sp"
            android:textColor="#B4D96C"
            android:fontFamily="@font/poppins_light"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvSliderLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sedang"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_medium" />
    </LinearLayout>

    <!-- Slider -->
    <com.google.android.material.slider.Slider
        android:id="@+id/slider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="1"
        android:valueTo="5"
        android:value="3"
        android:stepSize="1"
        app:trackColorActive="#B4D96C"
        app:trackColorInactive="#40FFFFFF"
        app:thumbColor="#B4D96C"
        app:thumbRadius="14dp"
        app:trackHeight="6dp"
        android:layout_marginBottom="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <!-- Labels at both ends -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvMinLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sangat Rendah"
            android:textSize="12sp"
            android:textColor="#80FFFFFF"
            android:fontFamily="@font/poppins_regular"
            android:gravity="start" />

        <TextView
            android:id="@+id/tvMaxLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sangat Tinggi"
            android:textSize="12sp"
            android:textColor="#80FFFFFF"
            android:fontFamily="@font/poppins_regular"
            android:gravity="end" />
    </LinearLayout>

</LinearLayout>
