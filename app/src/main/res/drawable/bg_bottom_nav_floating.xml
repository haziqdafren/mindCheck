<?xml version="1.0" encoding="utf-8"?>
<!-- Premium Floating Bottom Nav - Glassmorphism Pill -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Subtle outer glow effect -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#15FFFFFF" />
            <corners android:radius="36dp" />
        </shape>
    </item>

    <!-- Main glassmorphism surface with inset -->
    <item 
        android:top="2dp" 
        android:bottom="2dp" 
        android:left="2dp" 
        android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#25FFFFFF" />
            <corners android:radius="34dp" />
            <stroke 
                android:width="1dp" 
                android:color="#40FFFFFF" />
        </shape>
    </item>
    
</layer-list>
