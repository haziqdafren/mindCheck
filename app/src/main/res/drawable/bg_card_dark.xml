<?xml version="1.0" encoding="utf-8"?>
<!-- Modern Dark Card Background - Clean & Minimalist -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Card surface -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/cardBackgroundDark" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Subtle border -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="@color/borderDark" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
